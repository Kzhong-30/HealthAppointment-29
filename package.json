    "vue": "^3.4.21",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.14"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "tsx": "^4.22.4",
    "typescript": "~5.4.0",
    "vite": "^5.2.0",
    "vue-tsc": "^2.0.0",
    "ws": "^8.21.0",
    "y-websocket": "^2.1.0"
  }
}
