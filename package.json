{
  "name": "design-system-docs",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:ws": "VITE_COLLAB_MODE=websocket VITE_WEBSOCKET_URL=ws://localhost:1234 vite",
    "dev:webrtc": "VITE_COLLAB_MODE=webrtc VITE_SIGNALING_URLS=ws://localhost:4444 vite",
    "signaling": "PORT=4444 node scripts/signaling-server.js",
    "websocket-server": "HOST=0.0.0.0 PORT=1234 npx y-websocket",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test:exports": "tsx scripts/test-exports.ts"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
